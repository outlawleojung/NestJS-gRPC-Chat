{
  "name": "nestjs-grpc-chat",
  "version": "0.1.0",
  "description": "NestJS monorepo showcasing MSA with Gateway + gRPC + Socket.IO + NATS + Redis",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "nest build",
    "build:gateway": "nest build gateway",
    "build:account": "nest build account",
    "build:chat": "nest build chat",
    "build:friend": "nest build friend",
    "build:realtime-hub": "nest build realtime-hub",
    "start:gateway": "nest start gateway --watch",
    "start:account": "nest start account --watch",
    "start:chat": "nest start chat --watch",
    "start:friend": "nest start friend --watch",
    "start:realtime-hub": "nest start realtime-hub --watch",
    "start:all": "concurrently -k -n gateway,account,chat,friend,hub -c blue,green,magenta,cyan,yellow \"pnpm start:gateway\" \"pnpm start:account\" \"pnpm start:chat\" \"pnpm start:friend\" \"pnpm start:realtime-hub\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "ioredis": "^5.4.1",
    "nats": "^2.28.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
